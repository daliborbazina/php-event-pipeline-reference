{
    "name": "daliborbazina/php-event-pipeline-reference",
    "description": "Reference architecture for asynchronous domain event processing in PHP systems.",
    "type": "project",
    "license": "MIT",

    "require": {
        "php": "^8.3",
        "php-amqplib/php-amqplib": "^3.7"
    },

    "autoload": {
        "psr-4": {
            "App\\": "../app/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "../tests/"
        }
    },

    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^12.5"
    },

    "scripts": {
        "stan": "phpstan analyse",
        "fix": "php-cs-fixer fix --allow-risky=yes",
        "lint": "php-cs-fixer fix --dry-run --diff --allow-risky=yes"
    },

    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
