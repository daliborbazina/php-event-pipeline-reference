root = true

[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 4

[*.php]
indent_size = 4
indent_style = space

[*.php]
trim_trailing_whitespace = true
insert_final_newline     = true

[*.{yaml,yml,json,md}]
indent_size = 2

[*.js]
indent_size = 2

[*.css,*.scss]
indent_size = 2
